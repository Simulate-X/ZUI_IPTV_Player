{
  "name": "zui-iptv-player",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && node --require ./scripts/crypto-polyfill.cjs node_modules/vite/bin/vite.js build && npm run copy:webos",
    "copy:webos": "shx cp appinfo.json icon.png largeIcon.png dist/",
    "package": "ares-package dist -o dist-ipk",
    "install:tv": "ares-install -d tv dist-ipk/com.zui.player_1.0.0_all.ipk",
    "launch": "ares-launch -d tv com.zui.player",
    "inspect": "ares-inspect -d tv -a com.zui.player -o",
    "preview": "vite preview"
  },
  "dependencies": {
    "@noriginmedia/norigin-spatial-navigation": "^1.3.3",
    "class-variance-authority": "^0.7.1",
    "fast-xml-parser": "^4.5.6",
    "hls.js": "1.5",
    "idb": "^8.0.3",
    "iptv-playlist-parser": "^0.13.0",
    "mpegts.js": "1.7",
    "nanoid": "^5.1.11",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-window": "^2.2.7",
    "zustand": "4.5"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-window": "^2.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "shx": "^0.3.4",
    "tailwindcss": "^3.4.0",
    "terser": "^5.47.1",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
